# REST API endpoint to publish updates
API_URL=https://your-website.com/api/updates

# HTTP method (POST, PUT, PATCH)
API_METHOD=POST

# Auth header type and value
# Leave empty if no auth needed
API_AUTH_HEADER=Authorization
API_AUTH_VALUE=Bearer your-token-here

# Optional: Custom headers as JSON
# API_EXTRA_HEADERS={"X-Custom":"value"}

# Your name/role signature
AUTHOR_NAME=Your Name
AUTHOR_ROLE=Developer
